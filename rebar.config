{erl_opts, [debug_info, {i, "include"}]}.

{deps, [
    {jsx, "3.1.0"},
    {cowboy, "2.12.0"},
    {rocksdb, {git, "https://github.com/emqx/erlang-rocksdb.git",
               {tag, "9.10.0-emqx-2"}}},
    {chumak, "1.4.0"}
]}.

{pre_hooks, [{compile, "make -C c_src"}]}.
{post_hooks, [{clean, "make -C c_src clean"}]}.

{shell, [{apps, [beamchain]}]}.

{project_plugins, [rebar3_hex]}.

{profiles, [
    {test, [
        {erl_opts, [nowarn_export_all]},
        {deps, []}
    ]}
]}.

%% NOTE: escript mode is NOT supported for beamchain because rocksdb
%% uses a NIF (.so shared library) which cannot be loaded from inside
%% an escript zip archive. Use the release build instead:
%%   rebar3 as prod release
%%   _build/prod/rel/beamchain/bin/beamchain daemon
%% or use rebar3 shell for development.
{escript_incl_apps, [beamchain, jsx, rocksdb, cowboy, chumak]}.
{escript_main_app, beamchain}.
{escript_name, beamchain}.
{escript_emu_args, "%%! -escript main beamchain_cli\n"}.

{relx, [{release, {beamchain, "0.1.0"}, [beamchain, rocksdb, sasl]},
        {dev_mode, false},
        {include_erts, true},
        {extended_start_script, true},
        {sys_config, "config/sys.config"},
        {vm_args, "config/vm.args"}]}.

%% Include all dependency BEAMs in the PLT so that calls to dependency
%% functions (e.g. chumak) are resolved rather than reported as Unknown.
{dialyzer, [
    {plt_apps, all_deps},
    {plt_extra_apps, [chumak]}
]}.

%% xref: only run the checks that catch REAL bugs. We skip exports_not_used
%% because modules like beamchain_wallet deliberately export many helpers
%% that aren't called from within the project (they're called from the
%% shell, tests, or external integrations), and the noise would drown out
%% signal. undefined_function_calls is the critical one — it's what catches
%% things like ets:fun2ms/1 being referenced without the ms_transform
%% parse transform include (see commit 73646bd).
{xref_checks, [
    undefined_function_calls,
    undefined_functions,
    locals_not_used,
    deprecated_function_calls
]}.

%% xref ignores — two categories:
%%
%% 1. chumak:{bind/4, socket/1, stop/1, send_multipart/2}
%%    The ZMQ dep is declared in rebar.config but its BEAM files aren't
%%    always bundled in the release, which makes xref report its calls
%%    as undefined even though they resolve at runtime. When chumak is
%%    actually present these ignores become no-ops; when it's absent
%%    beamchain_zmq falls back to a stub.
%%
%% 2. rocksdb:write/3
%%    The erlang-rocksdb dep deprecated write/3 in favor of a newer
%%    signature, but the calls at beamchain_db.erl:{387,403,585} still
%%    work at runtime. Tracked as tech debt — remove these ignores once
%%    the call sites are migrated. Do not add new rocksdb:write/3 calls
%%    without also removing the corresponding ignore.
{xref_ignores, [
    {chumak, bind, 4},
    {chumak, socket, 1},
    {chumak, stop, 1},
    {chumak, send_multipart, 2},
    {rocksdb, write, 3}
]}.
