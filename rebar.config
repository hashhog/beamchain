{erl_opts, [debug_info, {i, "include"}]}.

{deps, [
    {jsx, "3.1.0"},
    {cowboy, "2.12.0"},
    {rocksdb, {git, "https://github.com/emqx/erlang-rocksdb.git",
               {tag, "9.10.0-emqx-2"}}},
    {chumak, "1.4.0"}
]}.

{pre_hooks, [{compile, "make -C c_src"}]}.
{post_hooks, [{clean, "make -C c_src clean"}]}.

{shell, [{apps, [beamchain]}]}.

{project_plugins, [rebar3_hex]}.

{profiles, [
    {test, [
        {erl_opts, [nowarn_export_all]},
        {deps, []}
    ]}
]}.

%% NOTE: escript mode is NOT supported for beamchain because rocksdb
%% uses a NIF (.so shared library) which cannot be loaded from inside
%% an escript zip archive. Use the release build instead:
%%   rebar3 as prod release
%%   _build/prod/rel/beamchain/bin/beamchain daemon
%% or use rebar3 shell for development.
{escript_incl_apps, [beamchain, jsx, rocksdb, cowboy, chumak]}.
{escript_main_app, beamchain}.
{escript_name, beamchain}.
{escript_emu_args, "%%! -escript main beamchain_cli\n"}.

{relx, [{release, {beamchain, "0.1.0"}, [beamchain, rocksdb, sasl]},
        {dev_mode, false},
        {include_erts, true},
        {extended_start_script, true},
        {sys_config, "config/sys.config"},
        {vm_args, "config/vm.args"}]}.
